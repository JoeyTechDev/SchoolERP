# Normalize all text files to LF in the repository
* text=auto

# PHP
*.php text eol=lf

# JavaScript
*.js text eol=lf

# CSS
*.css text eol=lf

# HTML
*.html text eol=lf

# Markdown
*.md text eol=lf

# JSON
*.json text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary