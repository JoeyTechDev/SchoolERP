# ------------------------------------------------------------------
# SchoolERP Git Ignore
# ------------------------------------------------------------------

# ==========================
# Composer
# ==========================
/vendor/

# ==========================
# Environment Files
# ==========================
.env
.env.*
!.env.example

# ==========================
# IDE Settings
# ==========================
.vscode/
.idea/

# ==========================
# OS Files
# ==========================
.DS_Store
Thumbs.db
desktop.ini

# ==========================
# Logs
# ==========================
*.log
logs/

# ==========================
# Cache
# ==========================
cache/
storage/cache/

# ==========================
# PHPUnit
# ==========================
.phpunit.result.cache

# ==========================
# Node.js
# ==========================
node_modules/

# ==========================
# Temporary Files
# ==========================
*.tmp
*.temp
*.bak
*.swp

# ==========================
# Runtime Uploads
# ==========================
public/uploads/

# ==========================
# Generated Files
# ==========================
coverage/
build/

# ==========================
# Database Backups
# ==========================
*.sql
*.sqlite
*.sqlite3